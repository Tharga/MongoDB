@page "/database"

<RadzenCard Style="margin-bottom: 6px;">
    <Tharga.MongoDB.Blazor.MonitorToolbar OnCallsReset="OnCallsReset" OnCacheReset="OnCacheReset" />
</RadzenCard>

<RadzenTabs>
    <Tabs>
        <RadzenTabsItem Text="Collections">
            <Tharga.MongoDB.Blazor.CollectionView @ref="_collectionView" />
        </RadzenTabsItem>
        <RadzenTabsItem Text="Calls">
            <Tharga.MongoDB.Blazor.CallView @ref="_callView" />
        </RadzenTabsItem>
    </Tabs>
</RadzenTabs>

@code {
    private Tharga.MongoDB.Blazor.CollectionView _collectionView;
    private Tharga.MongoDB.Blazor.CallView _callView;

    private async Task OnCallsReset()
    {
        if (_callView != null) await _callView.RefreshAsync();
    }

    private async Task OnCacheReset()
    {
        if (_collectionView != null) await _collectionView.RefreshAsync();
    }
}
