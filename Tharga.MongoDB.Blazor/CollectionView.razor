@using Microsoft.Extensions.Options
@using Tharga.Blazor
@using Tharga.Blazor.Framework.Buttons
@using Tharga.MongoDB
@using Tharga.MongoDB.Configuration
@using Tharga.Toolkit
@implements IDisposable
@inject IDatabaseMonitor DatabaseMonitor;
@inject DialogService DialogService
@inject IOptions<DatabaseOptions> DatabaseOptions
@inject ICallLibrary CallLibrary

@if (!DatabaseOptions.Value.Monitor.Enabled)
{
    <RadzenText>Database monitor is disabled.</RadzenText>
}
else if (_model == null)
{
    <Loading />
}
else
{
    <RadzenStack Orientation="Orientation.Vertical">
        <RadzenRow>
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Vertical">
                    <RadzenText TextStyle="TextStyle.Caption" Text="Registration" />
                    <RadzenSelectBar TValue="IEnumerable<Registration>" @bind-Value="@SelectedRegistrationTypes" Change="@ReloadDataAsync" Style="margin-bottom: 6px;" Multiple="true">
                        <Items>
                            <RadzenSelectBarItem Text="Static" Value="Registration.Static" />
                            <RadzenSelectBarItem Text="Dynamic" Value="Registration.Dynamic" />
                            <RadzenSelectBarItem Text="Not in Code" Value="Registration.NotInCode" />
                        </Items>
                    </RadzenSelectBar>
                </RadzenStack>
            </RadzenColumn>
            @if (_sources.Length > 1)
            {
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Vertical">
                    <RadzenText TextStyle="TextStyle.Caption" Text="Sources"/>
                    <RadzenDropDown Placeholder="Select sources" @bind-Value=@SelectedSources Data=@_sources Multiple=true Style="margin-bottom: 6px;" Change="@ReloadDataAsync" />
                </RadzenStack>
            </RadzenColumn>
            }
            @if (_showDatabase)
            {
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Vertical">
                    <RadzenText TextStyle="TextStyle.Caption" Text="Databases"/>
                    <RadzenDropDown Placeholder="Select databases" @bind-Value=@SelectedDatabases Data=@_databases Multiple=true Style="margin-bottom: 6px;" Change="@ReloadDataAsync" />
                </RadzenStack>
            </RadzenColumn>
            }
        </RadzenRow>

        <RadzenDataGrid Data="_model" TItem="CollectionModel"
                        AllowFiltering="true" FilterMode="FilterMode.Simple" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                        AllowSorting="true"
                        AllowPaging="true" PageSize="8" PageSizeOptions="[8, 16, 32, 64]"
                        ShowPagingSummary="true" PagingSummaryFormat="@("{2:N0} collections, page {0} of {1}")"
                        CellRender="@OnCellRender">
            <Columns>
                <RadzenDataGridColumn Title="Source" Visible="@_showSource" Sortable="false" Filterable="false" Width="200px">
                    <Template>
                        @string.Join(", ", context.Sources)
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn Title="Configuration" Property="@nameof(CollectionModel.ConfigurationName)" Visible="@_showConfiguration" />
                <RadzenDataGridColumn Title="Database" Property="@nameof(CollectionModel.DatabaseName)" Visible="@_showDatabase" />
                <RadzenDataGridColumn Title="Collection" Property="@nameof(CollectionModel.CollectionName)" />
                <RadzenDataGridColumn Title="Discovery" Property="@nameof(CollectionModel.Discovery)" Filterable="false"/>
                <RadzenDataGridColumn Title="Registration" Property="@nameof(CollectionModel.Registration)" Filterable="false" Width="120px" />
                <RadzenDataGridColumn Title="Documents" TextAlign="TextAlign.Right" CssClass="css-count" Sortable="false" Filterable="false" Width="120px">
                    <Template>
                        <RadzenText Text="@(context.Stats != null ? $"{context.Stats.DocumentCount:N0}" : "")" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn Title="Size" TextAlign="TextAlign.Right" Filterable="false" CssClass="css-size" Sortable="false" Width="120px">
                    <Template>
                        @(context.Stats != null ? context.Stats.Size.ToReadableByteSize() : "")
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn Title="Indices" Property="@nameof(CollectionModel.IndexEqualFields)" CssClass="css-indices" Width="120px">
                    <Template>
                        <span title="@context.Indices.Diff()">@(context.IndexEqualFields?.ToString() ?? "")</span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn Title="Clean" Sortable="false" Filterable="false" CssClass="css-clean" Width="100px">
                    <Template>
                        @if (context.Clean != null)
                        {
                            <span title="@context.Clean.CleanedAt.ToLocalDateTimeString()">@context.Clean.CleanedAt.ToLocalDurationString()</span>
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn Title="Calls" Property="@nameof(CollectionModel.CallCount)" Filterable="false" Sortable="true" TextAlign="TextAlign.Right" Width="80px">
                    <Template>
                        @(context.CallCount > 0 ? $"{context.CallCount:N0}" : "")
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn Title="" Sortable="false" Width="60px;" Filterable="false">
                    <Template>
                        <StandardButton Icon="format_list_numbered" Click="@(() => ShowCollectionDialog(context))" Style="margin-right: 3px;" Visible="@context.IsLocal" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenStack>
}

@code {
    private string[] _sources = [];
    private string[] _databases;
    private CollectionModel[] _model;
    private bool _showConfiguration;
    private bool _showSource;
    private bool _showDatabase;
    private CollectionInfo[] _all;

    private IEnumerable<Registration> SelectedRegistrationTypes { get; set; }
    private IEnumerable<string> SelectedSources { get; set; }
    private IEnumerable<string> SelectedDatabases { get; set; }

    [Parameter]
    public bool FullDatabaseScan { get; set; }

    [Parameter]
    public string Filter { get; set; }

    protected override async Task OnInitializedAsync()
    {
        DatabaseMonitor.CollectionInfoChangedEvent += OnCollectionInfoChanged;
        DatabaseMonitor.CollectionDroppedEvent += OnCollectionDropped;
        CallLibrary.CallChanged += OnCallChanged;
        await base.OnInitializedAsync();
    }

    private bool _disposed;

    public void Dispose()
    {
        _disposed = true;
        DatabaseMonitor.CollectionInfoChangedEvent -= OnCollectionInfoChanged;
        DatabaseMonitor.CollectionDroppedEvent -= OnCollectionDropped;
        CallLibrary.CallChanged -= OnCallChanged;
    }

    private async void OnCallChanged(object sender, EventArgs e)
    {
        if (_disposed || _model == null) return;

        try { await InvokeAsync(() => { UpdateCallCounts(); StateHasChanged(); }); }
        catch (ObjectDisposedException) { }
    }

    private void UpdateCallCounts()
    {
        var callCounts = CallLibrary.GetCallCounts();
        foreach (var m in _model)
        {
            var suffix = $".{m.DatabaseName}.{m.CollectionName}";
            m.CallCount = callCounts
                .Where(kvp => kvp.Key.EndsWith(suffix))
                .Sum(kvp => kvp.Value);
        }
    }

    private async void OnCollectionInfoChanged(object sender, CollectionInfoChangedEventArgs e)
    {
        if (_disposed || _all == null) return;

        var item = _all.SingleOrDefault(x => x.Key == e.CollectionInfo.Key);

        if (item == null)
        {
            // New remote collection — add it and reload
            _all = _all.Append(e.CollectionInfo).ToArray();
            await ReloadDataAsync();
            if (_disposed) return;
            try { await InvokeAsync(StateHasChanged); } catch (Exception) { }
            return;
        }

        item.Discovery = e.CollectionInfo.Discovery;
        item.Stats = e.CollectionInfo.Stats;
        item.Index = e.CollectionInfo.Index;

        var m = _model?.SingleOrDefault(x => x.ConfigurationName == item.ConfigurationName && x.DatabaseName == item.DatabaseName && x.CollectionName == item.CollectionName);
        if (m != null)
        {
            var indexModels = e.CollectionInfo.ToIndexModel().ToArray();
            var sources = DatabaseMonitor.GetCollectionSources(item.Key).ToArray();

            m.Discovery = e.CollectionInfo.Discovery;
            m.Stats = e.CollectionInfo.Stats;
            m.Size = e.CollectionInfo.Stats?.Size ?? 0;
            m.Indices = indexModels;
            m.IndexEqualFields = e.CollectionInfo.Index == null || e.CollectionInfo.Index.Current == null ? null : indexModels.All(x => x.EqualFields);
            m.Clean = e.CollectionInfo.Clean;
            m.Sources = sources;

            _showSource = _model.SelectMany(x => x.Sources).Distinct().Count() > 1;
        }

        if (_disposed) return;
        try { await InvokeAsync(StateHasChanged); } catch (Exception) { }
    }

    private async void OnCollectionDropped(object sender, CollectionDroppedEventArgs e)
    {
        if (_disposed || _all == null) return;

        _all = _all.Where(x => x.ToDatabaseContext() != e.DatabaseContext).ToArray();
        await ReloadDataAsync();

        if (_disposed) return;
        try { await InvokeAsync(StateHasChanged); } catch (Exception) { }
    }

    protected override async Task OnParametersSetAsync()
    {
        _all = await DatabaseMonitor.GetInstancesAsync(FullDatabaseScan, Filter).ToArrayAsync();
        await ReloadDataAsync();
        await base.OnParametersSetAsync();
    }

    public async Task RefreshAsync()
    {
        _all = await DatabaseMonitor.GetInstancesAsync(FullDatabaseScan, Filter).ToArrayAsync();
        await ReloadDataAsync();
    }

    private async Task ShowCollectionDialog(CollectionModel context)
    {
        var parameters = new Dictionary<string, object> { { "Fingerprint", context } };
        var dialogOptions = new DialogOptions { Resizable = true, Draggable = true };
        var result = await DialogService.OpenAsync<CollectionDialog>(context.CollectionName, parameters, dialogOptions);
        if (result != true) return;

        await ReloadDataAsync();
    }

    private async Task ReloadDataAsync()
    {
        var callCounts = CallLibrary.GetCallCounts();

        // Build all models with sources
        var allModels = _all
            .Select(x =>
            {
                var indexModels = x.ToIndexModel().ToArray();
                var suffix = $".{x.DatabaseName}.{x.CollectionName}";
                var count = callCounts
                    .Where(kvp => kvp.Key.EndsWith(suffix))
                    .Sum(kvp => kvp.Value);

                var sources = DatabaseMonitor.GetCollectionSources(x.Key).ToArray();
                var isLocal = x.CollectionType != null;

                return new CollectionModel
                {
                    ConfigurationName = x.ConfigurationName,
                    Stats = x.Stats,
                    DatabaseName = x.DatabaseName,
                    CollectionName = x.CollectionName,
                    Discovery = x.Discovery,
                    Registration = x.Registration,
                    Size = x.Stats?.Size ?? 0,
                    Indices = indexModels,
                    IndexEqualFields = x.Index == null || x.Index.Current == null
                        ? null
                        : indexModels.All(y => y.EqualFields),
                    Clean = x.Clean,
                    CallCount = count,
                    Sources = sources,
                    IsLocal = isLocal,
                };
            })
            .ToArray();

        // Populate filter options from unfiltered data
        _sources = allModels.SelectMany(x => x.Sources).Distinct().Order().ToArray();
        _databases = allModels.Select(x => x.DatabaseName).Distinct().Order().ToArray();

        // Apply filters
        _model = allModels
            .Where(x => SelectedSources == null || !SelectedSources.Any() || x.Sources.Any(s => SelectedSources.Contains(s)))
            .Where(x => SelectedDatabases == null || !SelectedDatabases.Any() || SelectedDatabases.Contains(x.DatabaseName))
            .Where(x => SelectedRegistrationTypes == null || !SelectedRegistrationTypes.Any() || SelectedRegistrationTypes.Contains(x.Registration))
            .ToArray();

        _showConfiguration = allModels.Select(x => x.ConfigurationName).Distinct().Count() > 1;
        _showDatabase = allModels.Select(x => x.DatabaseName).Distinct().Count() > 1;
        _showSource = _sources.Length > 1;
        StateHasChanged();
    }

    void OnCellRender(DataGridCellRenderEventArgs<CollectionModel> args)
    {
        var cssClass = args.Column.CssClass;
        if (string.IsNullOrEmpty(cssClass)) return;

        if (cssClass.StartsWith("css-count"))
        {
            string color = args.Data.Stats == null ? "lightyellow" : null;
            SetColor(args, color);
        }
        else if (cssClass.StartsWith("css-size"))
        {
            string color = args.Data.Stats == null ? "lightyellow" : null;
            SetColor(args, color);
        }
        else if (cssClass.StartsWith("css-indices"))
        {
            string color = null;
            if (args.Data.IndexEqualFields == null)
            {
                color = "lightyellow";
            }
            else if (args.Data.IndexEqualFields == false)
            {
                color = "pink";
            }

            SetColor(args, color);
        }
        else if (cssClass.StartsWith("css-clean"))
        {
            string color = args.Data.Clean == null ? "lightyellow" : null;
            SetColor(args, color);
        }
    }

    private static void SetColor(DataGridCellRenderEventArgs<CollectionModel> args, string color)
    {
        if (color is null) return;

        if (args.Attributes.TryGetValue("style", out var existing))
        {
            args.Attributes["style"] = existing + $"background-color: {color};";
        }
        else
        {
            args.Attributes.Add("style", $"background-color: {color};");
        }
    }

}
