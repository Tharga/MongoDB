@using Microsoft.Extensions.Options
@using Tharga.Blazor
@using Tharga.Blazor.Framework.Buttons
@using Tharga.MongoDB.Configuration
@using Tharga.MongoDB.Disk
@implements IDisposable
@inject IDatabaseMonitor DatabaseMonitor;
@inject IOptions<DatabaseOptions> DatabaseOptions
@inject DialogService DialogService
@inject ICallLibrary CallLibrary

@if (!DatabaseOptions.Value.Monitor.Enabled)
{
    <RadzenText>Database monitor is disabled.</RadzenText>
}
else if (_model == null)
{
    <Loading />
}
else
{
    <RadzenStack Orientation="Orientation.Vertical">

        <RadzenRow>
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Vertical">
                    <RadzenText TextStyle="TextStyle.Caption" Text="Type"/>
                    <RadzenSelectBar TValue="string" @bind-Value="@SelectedTab" Change="@OnTabChanged" Style="margin-bottom: 6px;">
                        <Items>
                            <RadzenSelectBarItem Text="Last" Value="@("Last")"/>
                            <RadzenSelectBarItem Text="Slow" Value="@("Slow")"/>
                            <RadzenSelectBarItem Text="Ongoing" Value="@("Ongoing")"/>
                            <RadzenSelectBarItem Text="Queue" Value="@("Queue")"/>
                        </Items>
                    </RadzenSelectBar>
                </RadzenStack>
            </RadzenColumn>
            @if (_sources.Length > 1)
            {
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Vertical">
                    <RadzenText TextStyle="TextStyle.Caption" Text="Sources"/>
                    <RadzenDropDown Placeholder="Select sources" @bind-Value=@SelectedSources Data=@_sources Multiple=true Style="margin-bottom: 6px;" Change="@ReloadDataAsync" />
                </RadzenStack>
            </RadzenColumn>
            }
            @if (_databases.Length > 1)
            {
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Vertical">
                    <RadzenText TextStyle="TextStyle.Caption" Text="Databases"/>
                    <RadzenDropDown Placeholder="Select databases" @bind-Value=@SelectedDatabases Data=@_databases Multiple=true Style="margin-bottom: 6px;" Change="@ReloadDataAsync" />
                </RadzenStack>
            </RadzenColumn>
            }
        </RadzenRow>

        @if (SelectedTab == "Queue")
        {
            <QueueView />
        }
        else
        {
        <RadzenRow>
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Vertical">
                    <RadzenText TextStyle="TextStyle.Caption" Text="Collections"/>
                    <RadzenDropDown Placeholder="Select collections" @bind-Value=@SelectedCollections Data=@_collections Multiple=true Style="margin-bottom: 6px;" Change="@ReloadDataAsync" />
                </RadzenStack>
            </RadzenColumn>
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Vertical">
                    <RadzenText TextStyle="TextStyle.Caption" Text="Functions"/>
                    <RadzenDropDown Placeholder="Select functions" @bind-Value=@SelectedFunctions Data=@_functions Multiple=true Style="margin-bottom: 6px;" Change="@ReloadDataAsync" />
                </RadzenStack>
            </RadzenColumn>
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Vertical">
                    <RadzenText TextStyle="TextStyle.Caption" Text="Operations"/>
                    <RadzenDropDown Placeholder="Select operations" @bind-Value=@SelectedOperations Data=@_operations Multiple=true Style="margin-bottom: 6px;" Change="@ReloadDataAsync" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>

        <RadzenDataGrid Data="_model" TItem="CallInfo"
                        AllowFiltering="false" FilterMode="FilterMode.Simple" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                        AllowSorting="true"
                        AllowPaging="true" PageSize="8" PageSizeOptions="[8, 16, 32, 64]"
                        ShowPagingSummary="true" PagingSummaryFormat="@("{2:N0} calls, page {0} of {1}")"
                        CellRender="@OnCellRender">
            <Columns>
                <RadzenDataGridColumn Title="Start" Property="@nameof(CallInfo.StartTime)" SortOrder="SortOrder.Descending">
                    <Template>
                        <DateTimeView Date="@context.StartTime"/>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn Title="Source" Property="@nameof(CallInfo.SourceName)" Visible="@_showSource" />
                <RadzenDataGridColumn Title="Configuration" Property="@($"{nameof(CallInfo.Fingerprint)}.{nameof(CallInfo.Fingerprint.ConfigurationName)}")" Visible="@_showConfiguration" />
                <RadzenDataGridColumn Title="Database" Property="@($"{nameof(CallInfo.Fingerprint)}.{nameof(CallInfo.Fingerprint.DatabaseName)}")" Visible="@_showDatabase" />
                <RadzenDataGridColumn Title="Collection" Property="@($"{nameof(CallInfo.Fingerprint)}.{nameof(CallInfo.Fingerprint.CollectionName)}")" />
                <RadzenDataGridColumn Title="Function" Property="@nameof(CallInfo.FunctionName)"/>
                <RadzenDataGridColumn Title="Operation" Property="@nameof(CallInfo.Operation)"/>
                <RadzenDataGridColumn Title="Count" Property="@nameof(CallInfo.Count)"/>
                <RadzenDataGridColumn Title="Elapsed" Property="@nameof(CallInfo.Elapsed)" CssClass="final">
                    <Template>
                        <TimeSpanView TimeSpan="@context.Elapsed"/>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn Title="Exception" Sortable="false" Filterable="false">
                    <Template>
                        @context.Exception?.Message
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn Title="" Sortable="false" Width="60px;" Filterable="false">
                    <Template>
                        <StandardButton Icon="format_list_numbered" Click="@(() => ShowCallDialog(context))" Style="margin-right: 3px;" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
        }
    </RadzenStack>
}

@code {
    private string[] _sources;
    private string[] _databases;
    private string[] _collections;
    private string[] _functions;
    private Operation[] _operations;
    private CallInfo[] _model;
    private bool _showConfiguration;
    private bool _showDatabase;
    private bool _showSource;
    private CallInfo[] _all;
    private bool _disposed;

    private string SelectedTab { get; set; } = "Last";
    private IEnumerable<string> SelectedSources { get; set; }
    private IEnumerable<string> SelectedDatabases { get; set; }
    private IEnumerable<string> SelectedCollections { get; set; }
    private IEnumerable<string> SelectedFunctions { get; set; }
    private IEnumerable<Operation> SelectedOperations { get; set; }

    private CallType SelectedCallType => SelectedTab switch
    {
        "Last" => CallType.Last,
        "Slow" => CallType.Slow,
        "Ongoing" => CallType.Ongoing,
        _ => CallType.Last
    };

    private async Task OnTabChanged()
    {
        if (SelectedTab != "Queue")
        {
            await ReloadDataAsync();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        CallLibrary.CallChanged += OnCallChanged;
        await base.OnInitializedAsync();
    }

    public void Dispose()
    {
        _disposed = true;
        CallLibrary.CallChanged -= OnCallChanged;
    }

    private async void OnCallChanged(object sender, EventArgs e)
    {
        if (_disposed) return;
        if (SelectedTab != "Ongoing") return;

        try { await InvokeAsync(async () => { await ReloadDataAsync(); StateHasChanged(); }); }
        catch (ObjectDisposedException) { }
    }

    protected override async Task OnParametersSetAsync()
    {
        UpdateFilterOptions();
        await ReloadDataAsync();
        await base.OnParametersSetAsync();
    }

    private void UpdateFilterOptions()
    {
        var allCalls = DatabaseMonitor.GetCalls(CallType.Last)
            .Union(DatabaseMonitor.GetCalls(CallType.Slow))
            .Union(DatabaseMonitor.GetCalls(CallType.Ongoing))
            .ToArray();
        _sources = allCalls.Select(x => x.SourceName).Where(x => x != null).Distinct().Order().ToArray();
        _databases = allCalls.Select(x => x.Fingerprint.DatabaseName).Distinct().Order().ToArray();
        _collections = allCalls.Select(x => x.Fingerprint.CollectionName).Distinct().Order().ToArray();
        _functions = allCalls.Select(x => x.FunctionName).Distinct().Order().ToArray();
        _operations = allCalls.Select(x => x.Operation).Distinct().Order().ToArray();
    }

    void OnCellRender(DataGridCellRenderEventArgs<CallInfo> args)
    {
        var cssClass = args.Column.CssClass;
        if (string.IsNullOrEmpty(cssClass) || !cssClass.StartsWith("final")) return;

        string color = null;
        if (!args.Data.Final)
        {
            color = "lightyellow";
        }

        if (color is null) return;

        if (args.Attributes.TryGetValue("style", out var existing))
        {
            args.Attributes["style"] = existing + $"background-color: {color};";
        }
        else
        {
            args.Attributes.Add("style", $"background-color: {color};");
        }
    }

    private async Task ReloadDataAsync()
    {
        _all = DatabaseMonitor.GetCalls(SelectedCallType).ToArray();
        _model = _all
            .Where(x => SelectedSources == null || !SelectedSources.Any() || SelectedSources.Contains(x.SourceName))
            .Where(x => SelectedDatabases == null || !SelectedDatabases.Any() || SelectedDatabases.Contains(x.Fingerprint.DatabaseName))
            .Where(x => SelectedCollections == null || !SelectedCollections.Any() || SelectedCollections.Contains(x.Fingerprint.CollectionName))
            .Where(x => SelectedFunctions == null || !SelectedFunctions.Any() || SelectedFunctions.Contains(x.FunctionName))
            .Where(x => SelectedOperations == null || !SelectedOperations.Any() || SelectedOperations.Contains(x.Operation))
            .ToArray();
        _showSource = _sources.Length > 1;
        _showConfiguration = _all.Select(x => x.Fingerprint.ConfigurationName).Distinct().Count() > 1;
        _showDatabase = _all.Select(x => x.Fingerprint.DatabaseName).Distinct().Count() > 1;
        StateHasChanged();
    }

    public async Task RefreshAsync()
    {
        await ReloadDataAsync();
    }

    private async Task ShowCallDialog(CallInfo context)
    {
        var parameters = new Dictionary<string, object> { { "Key", context.Key } };
        var dialogOptions = new DialogOptions { Resizable = true, Draggable = true };
        var result = await DialogService.OpenAsync<CallDialog>($"{context.FunctionName} {context.Fingerprint.CollectionName}", parameters, dialogOptions);
        if (result != true) return;

        await ReloadDataAsync();
    }

}
