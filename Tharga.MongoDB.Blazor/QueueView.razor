@implements IDisposable
@inject IQueueMonitor QueueMonitor

<RadzenStack Orientation="Orientation.Vertical" Gap="16px">
    <RadzenRow AlignItems="AlignItems.Center" Gap="16px">
        <RadzenColumn Size="2">
            <RadzenText TextStyle="TextStyle.Subtitle1" Text="Current Queue" />
            <RadzenText TextStyle="TextStyle.H3" Text="@_currentQueue.ToString()" />
        </RadzenColumn>
    </RadzenRow>

    <RadzenText TextStyle="TextStyle.Subtitle1" Text="Queue Depth" />
    <RadzenChart Style="height: 250px;">
        <RadzenLineSeries Data="@_slots" CategoryProperty="SlotIndex" ValueProperty="QueueCount" LineType="LineType.Solid" Smooth="true">
            <RadzenMarkers MarkerType="MarkerType.None" />
        </RadzenLineSeries>
        <RadzenCategoryAxis Step="@AxisStep" FormatString="{0}" />
        <RadzenValueAxis Min="0">
            <RadzenGridLines Visible="true" />
        </RadzenValueAxis>
        <RadzenLegend Visible="false" />
    </RadzenChart>

    <RadzenText TextStyle="TextStyle.Subtitle1" Text="Wait Time (s)" />
    <RadzenChart Style="height: 250px;">
        <RadzenLineSeries Data="@_slots" CategoryProperty="SlotIndex" ValueProperty="WaitTimeSec" LineType="LineType.Solid" Smooth="true">
            <RadzenMarkers MarkerType="MarkerType.None" />
        </RadzenLineSeries>
        <RadzenCategoryAxis Step="@AxisStep" FormatString="{0}" />
        <RadzenValueAxis Min="0">
            <RadzenGridLines Visible="true" />
        </RadzenValueAxis>
        <RadzenLegend Visible="false" />
    </RadzenChart>

</RadzenStack>

@code {
    private const int TotalSlots = 120;
    private const int AxisStep = 20;
    private const int SampleIntervalMs = 500;
    private readonly int[] _ring = new int[TotalSlots];
    private readonly double[] _waitRing = new double[TotalSlots];
    private int _head;
    private int _currentQueue;
    private int _lastKnownQueue;
    private double _lastWaitTimeMs;
    private Timer _timer;
    private bool _disposed;
    private List<Slot> _slots = new();

    protected override void OnInitialized()
    {
        var metrics = QueueMonitor.GetRecentMetrics();
        if (metrics.Count > 0)
        {
            _lastKnownQueue = metrics[^1].QueueCount;
            _currentQueue = _lastKnownQueue;
        }

        BuildSlots();
        QueueMonitor.QueueMetricEvent += OnMetric;
        _timer = new Timer(OnTick, null, SampleIntervalMs, SampleIntervalMs);
    }

    public void Dispose()
    {
        _disposed = true;
        _timer?.Dispose();
        QueueMonitor.QueueMetricEvent -= OnMetric;
    }

    private void OnMetric(object sender, QueueMetricEventArgs e)
    {
        _lastKnownQueue = e.QueueCount;
        if (e.WaitTime.HasValue)
            _lastWaitTimeMs = Math.Max(_lastWaitTimeMs, e.WaitTime.Value.TotalMilliseconds);
    }

    private async void OnTick(object state)
    {
        if (_disposed) return;

        try
        {
            await InvokeAsync(() =>
            {
                _currentQueue = _lastKnownQueue;
                _ring[_head] = _lastKnownQueue;
                _waitRing[_head] = _lastWaitTimeMs;
                _lastWaitTimeMs = 0;
                _head = (_head + 1) % TotalSlots;

                BuildSlots();
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException) { }
    }

    private void BuildSlots()
    {
        var list = new List<Slot>(TotalSlots);
        for (var i = 0; i < TotalSlots; i++)
        {
            // i=0 → newest (head-1), i=119 → oldest (head)
            var ringIdx = (_head - 1 - i + TotalSlots) % TotalSlots;
            list.Add(new Slot
            {
                SlotIndex = i,
                QueueCount = _ring[ringIdx],
                WaitTimeSec = _waitRing[ringIdx] / 1000.0,
            });
        }
        _slots = list;
    }

    private class Slot
    {
        public int SlotIndex { get; init; }
        public int QueueCount { get; init; }
        public double WaitTimeSec { get; init; }
    }
}
