{
  "attribution": {
    "commit": "",
    "pr": ""
  },  
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git branch:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(cp .claude/feature.md .claude/features-done/*)",
      "Bash(rm .claude/feature.md)",
      "Bash(rm .claude/plan.md)",
      "Bash(rm .claude/features-planned/*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)"
    ]
  }
}
